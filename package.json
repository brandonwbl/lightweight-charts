{
  "name": "lightweight-charts",
  "version": "4.2.0",
  "description": "Performant financial charts built with HTML5 canvas",
  "keywords": [
    "charting",
    "charts",
    "canvas",
    "financial",
    "trading"
  ],
  "homepage": "https://github.com/tradingview/lightweight-charts",
  "bugs": {
    "url": "https://github.com/tradingview/lightweight-charts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tradingview/lightweight-charts.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/lightweight-charts.production.mjs",
      "require": "./dist/lightweight-charts.production.cjs"
    },
    "./dev": {
      "import": "./dist/lightweight-charts.development.mjs",
      "require": "./dist/lightweight-charts.development.cjs"
    }
  },
  "main": "./dist/lightweight-charts.production.cjs",
  "module": "./dist/lightweight-charts.production.mjs",
  "types": "./dist/typings.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:dev": "rollup -c rollup.config.js --environment BUILD:development",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
